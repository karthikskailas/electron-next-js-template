{
  "name": "electron-next-js-template",
  "version": "1.0.0",
  "description": "Electron + Next.js Desktop Application Template",
  "author": "Your Name",
  "license": "MIT",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k \"npm run dev:next\" \"npm run dev:electron-watch\" \"npm run dev:electron-start\" --names \"NEXT,TSUP,ELECTRON\" -c \"bgBlue.bold,bgYellow.bold,bgMagenta.bold\"",
    "dev:next": "next dev -p 3000",
    "dev:electron-watch": "tsup --watch",
    "dev:electron-start": "wait-on http://localhost:3000 && electron .",
    "build": "npm run build:next && npm run build:electron",
    "build:next": "next build",
    "build:electron": "tsup",
    "start": "electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "lint": "next lint"
  },
  "dependencies": {
    "electron-serve": "^2.1.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.4",
    "@types/node": "^22.13.14",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "concurrently": "^9.1.2",
    "electron": "^35.1.2",
    "electron-builder": "^26.0.12",
    "next": "^16.2.4",
    "postcss": "^8.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.4",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "wait-on": "^8.0.3"
  }
}
